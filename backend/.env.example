# ---- Runtime ----
NODE_ENV=development
PORT=5050
LOG_LEVEL=info
# Comma-separated list of allowed frontend origins (leave empty in dev to allow all)
CLIENT_URL=http://localhost:3000

# ---- Database ----
# Either set discrete PG* vars (local dev) ...
PGUSER=postgres
PGHOST=127.0.0.1
PGNAME=medichain
PGPASSWORD=change-me
PGPORT=5432
# ... or a single connection string (managed Postgres). DATABASE_URL wins when set.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGSSL=true

# ---- Auth ----
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ---- IPFS (Pinata) ----
# Create a JWT at https://app.pinata.cloud/developers/api-keys
IPFS_JWT=
IPFS_API_KEY=
IPFS_API_SECRET=

# ---- Blockchain ----
# Local Hardhat: http://127.0.0.1:8545 | Sepolia: your Alchemy/Infura URL
RPC_URL=http://127.0.0.1:8545
# Wallet that holds the UPLOADER_ROLE (NEVER commit a real key)
PRIVATE_KEY=
CONTRACT_ADDRESS=
CHAIN_ID=31337
# CONTRACT_ABI_PATH=/app/abi/ReportValidator.json

# ---- ML service ----
ML_SERVICE_URL=http://127.0.0.1:5001
ML_TIMEOUT_MS=30000
