# Secrets for `docker compose up`. Copy to `.env` and fill in.
# The stack boots with the defaults below; set these for full functionality.

# Postgres password (defaults to "postgres")
POSTGRES_PASSWORD=postgres

# Long random secret — generate with: openssl rand -hex 32
JWT_SECRET=please-change-this-in-production

# Pinata IPFS — required for the upload flow (https://app.pinata.cloud)
IPFS_JWT=
IPFS_API_KEY=
IPFS_API_SECRET=

# HuggingFace token for the ML service (https://huggingface.co/settings/tokens)
HF_ACCESS_TOKEN=
HF_XRAY_ID=Rishika08/chest-xray-pneumonia-detector
HF_VALIDATOR_ID=Rishika08/medical-report-validator

# Optional block explorer base for the frontend (empty for local chain)
NEXT_PUBLIC_EXPLORER_TX_URL=
